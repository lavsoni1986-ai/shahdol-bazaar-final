  HOSPITAL = "HOSPITAL",
  PHARMACY = "PHARMACY",
  GROCERY = "GROCERY",
  SCHOOL = "SCHOOL",
  BUS = "BUS",
  // NOTE: New split keys for electronics domain (Phase 1C-A preparatory)
  ELECTRONICS_STORE = "ELECTRONICS_STORE",
  ELECTRONICS_REPAIR = "ELECTRONICS_REPAIR"
}

export const CANONICAL_CATEGORIES = Object.values(CanonicalCategory);