// shared/contracts/ontology/domains.ts
// Canonical Domains - Single Source of Semantic Truth

export enum CanonicalDomain {
  HEALTHCARE = "HEALTHCARE",
  COMMERCE = "COMMERCE",
  EDUCATION = "EDUCATION",
  TRANSPORT = "TRANSPORT",
  GOVERNANCE = "GOVERNANCE",
  SERVICES = "SERVICES"
}

export const CANONICAL_DOMAINS = Object.values(CanonicalDomain);