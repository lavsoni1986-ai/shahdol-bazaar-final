# This is an example file. Copy this to .env.local for development
# and set these variables on your production server (Vercel, Netlify, etc.)

# The public URL of your frontend. Used for generating links in WhatsApp messages, etc.
# For development: http://localhost:5173
# For production: https://www.shahdolbazaar.com (or your actual domain)
VITE_APP_BASE_URL="http://localhost:5173"

# The base URL for your backend API.
# IMPORTANT: For local development, leave empty to use Vite proxy!
# Vite will automatically proxy /api/* requests to the backend.
# Backend should be running on http://localhost:5001
# For production: https://api.shahdolbazaar.com (or your actual API domain)
# VITE_API_URL=""

# OneSignal Push Notifications (optional)
# Get your App ID from: https://dashboard.onesignal.com/apps
# Leave empty to disable push notifications
VITE_ONESIGNAL_APP_ID=""
