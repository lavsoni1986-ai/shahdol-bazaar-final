  details   Json?
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@map("admin_log")
}

model FraudHistory {
  id        Int      @id @default(autoincrement())
  userId    Int?
  vendorId  Int?
  eventType String
  riskScore Float    @default(0)
  details   Json?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@index([userId])
  @@index([vendorId])
  @@map("fraud_history")
}

model UserIntelligence {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  intelligenceData Json?
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_intelligence")
}

model VendorMLProfile {
  id         Int      @id @default(autoincrement())
  vendorId   Int      @unique
  mlScore    Float    @default(0)
  trustScore Float    @default(0)
  updatedAt  DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_ml_profile")
}

model userPreference {
  id              Int   @id @default(autoincrement())
  userId          Int
  vendorId        Int
  preferenceScore Float @default(0)

  user   User   @relation(fields: [userId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([userId, vendorId])
  @@map("user_preference")
}

model systemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model adminActionLog {
  id        Int      @id @default(autoincrement())
  adminId   Int?
  action    String
  details   Json?
  createdAt DateTime @default(now())

  @@map("admin_action_log")
}

model SharedLearning {
  id         Int      @id @default(autoincrement())
  districtId Int
  query      String
  domain     String?
  createdAt  DateTime @default(now())

  @@map("shared_learning")
}

model VendorMetadata {
  id       Int @id @default(autoincrement())
  vendorId Int @unique

  // Core capabilities
  specializations  Json? // ["Cardiology", "Emergency"]
  businessHours    Json? // { monday: { open: "09:00", close: "18:00" }, ... }
  consultationMode String? // "IN_PERSON", "ONLINE", "BOTH"
  localityHint     String? // Neighborhood/area identifier
  tags             Json? // ["emergency", "24x7", "cashless"]

  // Live signals (NULLABLE = unknown, not false)
  emergencyAvailable Boolean? // null = unknown, true/false = verified
  deliveryActive     Boolean?
  acceptsInsurance   Boolean?
  homeVisit          Boolean?

  // Contact channels
  whatsappNumber String?

  // Quality signals
  lastVerified DateTime?
  dataPurity   Float? // 0-1, how complete the data is. null = unrated
  freshness    Float? // 0-1, age-weighted recency. null = uncomputed
  lastActivity DateTime?

  // Operational
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_metadata")
}

model CustomerProfile {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique @map("user_id")
  districtId Int      @map("district_id")
  fullName   String   @map("full_name")
  phone      String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([userId, districtId])
  @@index([userId])
  @@index([districtId])
  @@map("customer_profiles")
}

model Address {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  districtId    Int      @map("district_id")
  streetAddress String   @map("street_address")
  houseNumber   String?  @map("house_number")
  landmark      String?
  village       String?
  ward          String?
  city          String?
  districtName  String?  @map("district_name")
  state         String?
  postalCode    String?  @map("postal_code")
  type          String   @default("DELIVERY")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  district      District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([userId, id])
  @@index([userId])
  @@index([districtId])
  @@map("addresses")
}
