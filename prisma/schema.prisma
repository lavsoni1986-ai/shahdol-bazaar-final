generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model District {
  id              Int              @id @default(autoincrement())
  name            String
  slug            String           @unique
  state           String
  primaryColor    String           @default("#f97316")
  secondaryColor  String           @default("#22c55e")
  logoUrl         String?
  faviconUrl      String?
  dsslContact     String?
  dsslEmail       String?
  isActive        Boolean          @default(true)
  isDefault       Boolean          @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  admins          Admin[]
  analytics       AnalyticsEvent[] @relation("DistrictToAnalytics")
  buses           BusTimetable[]   @relation("DistrictToBuses")
  hospitals       Hospital[]       @relation("DistrictToHospitals")
  inquiries       Inquiry[]        @relation("DistrictToInquiries")
  offers          Offer[]
  serviceWorkers  ServiceWorker[]  @relation("DistrictToServiceWorkers")
  users           User[]
  vendors         Vendor[]         @relation("DistrictToVendors")

  @@map("District")
}

model Vendor {
  id                    Int          @id @default(autoincrement())
  name                  String
  slug                  String
  description           String?
  logo                  String?
  address               String?
  isVerified            Boolean      @default(false)
  createdAt             DateTime     @default(now())
  aiAdCopy              String?
  aiDescription         String?
  boostedUntil          DateTime?
  businessType          BusinessType @default(PRODUCT)
  category              String?
  categorySlug          String?
  districtId            Int?         @map("district_id")
  dsslLastUpdated       DateTime?
  dsslScore             Int          @default(100)
  experience            Int?         @default(0)
  hospitalData          Json?
  images                String[]
  isHospital            Boolean      @default(false)
  isProfessional        Boolean      @default(false)
  isTrending            Boolean      @default(false)
  legacyHospitalId      String?      @unique
  legacyShopId          Int?         @unique
  legacySchoolId        Int?         @map("legacy_school_id")
  mobile                String?
  phone                 String?
  safetyBadges          String[]
  serviceArea           String?
  serviceHours          String?
  specialties           String[]
  status                VendorStatus @default(PENDING)
  trendingScore         Int          @default(0)
  updatedAt             DateTime     @updatedAt
  userId                Int?         @map("user_id")
  vectorEmbedding       Json?
  whatsappNotifications Boolean      @default(false)
  doctors               Doctor[]     @relation("VendorToDoctors")
  inquiries             Inquiry[]
  offers                Offer[]
  products              Product[]
  district              District?    @relation("DistrictToVendors", fields: [districtId], references: [id])

  @@unique([districtId, slug])
  @@index([slug])
  @@index([businessType])
  @@index([districtId])
  @@index([status])
  @@index([isTrending])
  @@index([trendingScore])
  @@map("Vendor")
}

model Inquiry {
  id            String        @id @default(uuid())
  vendorId      Int?
  districtId    Int?          @map("district_id")
  customerName  String?
  customerPhone String
  customerEmail String?
  inquiryType   InquiryType   @default(LEAD)
  message       String?
  source        String        @default("website")
  status        InquiryStatus @default(NEW)
  preferredDate DateTime?
  preferredTime String?
  serviceType   String?
  doctorId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  district      District?     @relation("DistrictToInquiries", fields: [districtId], references: [id])
  vendor        Vendor?       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([districtId])
  @@index([status])
  @@index([createdAt])
  @@index([customerPhone])
  @@index([inquiryType])
  @@map("Inquiry")
}

model Shop {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String?  @unique
  description String?
  image       String?
  address     String?
  phone       String?
  mobile      String?
  category    String?
  isVerified  Boolean  @default(false)
  avgRating   Float?
  approved    Boolean  @default(false)
  ownerId     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Shop")
}

model Doctor {
  id              String   @id @default(uuid())
  name            String
  qualification   String?
  specialization  String?
  experience      Int      @default(0)
  consultationFee Float    @default(0)
  timing          String?
  image           String?
  hospitalId      String?
  vendorId        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vendor          Vendor?  @relation("VendorToDoctors", fields: [vendorId], references: [id])

  @@map("Doctor")
}

model Hospital {
  id                String    @id @default(uuid())
  name              String
  slug              String?   @unique
  address           String?
  contactNumber     String?
  email             String?
  description       String?
  images            String[]
  specialties       String[]
  isVerified        Boolean?  @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  ambulanceService  Boolean   @default(false) @map("ambulance_service")
  availableBeds     Int       @default(0) @map("available_beds")
  city              String?
  districtId        Int?      @map("district_id")
  emergencyBedCount Int       @default(0) @map("emergency_bed_count")
  emergencyPhone    String?   @map("emergency_phone")
  hospitalType      String    @default("multi_specialty")
  icuAvailable      Boolean   @default(false) @map("icu_available")
  is24x7            Boolean   @default(false)
  isActive          Boolean   @default(true)
  mapsLink          String?
  nabhAccredited    Boolean   @default(false) @map("nabh_accredited")
  openHours         String?
  oxygenAvailable   Boolean   @default(false) @map("oxygen_available")
  phone             String?
  pincode           String?
  totalBeds         Int       @default(0) @map("total_beds")
  userId            Int?      @map("user_id")
  website           String?
  district          District? @relation("DistrictToHospitals", fields: [districtId], references: [id])
  user              User?     @relation(fields: [userId], references: [id])

  @@map("Hospital")
}

model ShopAppointment {
  id            Int       @id @default(autoincrement())
  shopId        Int?
  shopName      String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  preferredDate DateTime? @db.Date
  preferredTime DateTime? @db.Time(6)
  serviceType   String?
  notes         String?
  status        String?   @default("pending")
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @db.Timestamp(6)

  @@map("ShopAppointment")
}

model Schools {
  id              Int      @id @default(autoincrement())
  name            String
  address         String
  contact         String?
  email           String?
  about           String?
  board           String?  @default("CBSE")
  vectorEmbedding Json?
  dsslScore       Int      @default(70)
  isVerified      Boolean  @default(false)
  safetyBadges    String[]

  @@map("Schools")
}

model SchoolCourses {
  id          Int     @id @default(autoincrement())
  schoolId    Int?
  className   String
  stream      String?
  description String?

  @@map("SchoolCourses")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]

  @@map("Category")
}

model Product {
  id              Int            @id @default(autoincrement())
  title           String         @map("name")
  description     String?
  imageUrl        String?        @map("image")
  virtualTryOn    Boolean        @default(false)
  vendorId        Int
  approved        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  aiAdCopy        String?
  aiDescription   String?
  categoryId      Int?
  categoryName    String?
  isTrending      Boolean        @default(false)
  mrp             Float?         @map("original_price")
  price           Float?         @map("selling_price")
  status          String         @default("pending")
  stock           Int            @default(100)
  vectorEmbedding Json?
  category        Category?      @relation(fields: [categoryId], references: [id])
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  images          ProductImage[]
  reviews         Review[]
  orders          Order[]

  @@index([vendorId])
  @@index([status])
  @@index([approved])
  @@index([categoryName])
  @@index([categoryId])
  @@index([createdAt])
  @@index([price])
  @@index([stock])
  @@index([isTrending])
  @@index([vendorId, status])
  @@index([approved, status])
  @@index([categoryName, status])
  @@map("Product")
}

model Review {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  userId     Int?     @map("user_id")
  rating     Int
  comment    String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@map("Review")
}

model Offer {
  id         Int       @id @default(autoincrement())
  content    String
  vendorId   Int?
  createdAt  DateTime  @default(now())
  isActive   Boolean   @default(true)
  type       String    @default("VENDOR_OFFER")
  userId     Int?
  districtId Int?      @map("district_id")
  district   District? @relation(fields: [districtId], references: [id])
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("Offer")
}

model User {
  id                   Int             @id @default(autoincrement())
  username             String          @unique
  password             String
  role                 String          @default("customer")
  isAdmin              Boolean         @default(false)
  shopName             String?         @map("shop_name")
  shopAddress          String?         @map("shop_address")
  mapsLink             String?         @map("maps_link")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  stripeCustomerId     String?         @map("stripe_customer_id")
  stripeSubscriptionId String?         @map("stripe_subscription_id")
  subscriptionPlan     String          @default("FREE") @map("subscription_plan")
  subscriptionStatus   String          @default("inactive") @map("subscription_status")
  subscriptionEndsAt   DateTime?       @map("subscription_ends_at")
  districtId           Int?            @map("district_id")
  consentAt            DateTime?       @map("consent_at")
  consentGiven         Boolean         @default(false) @map("consent_given")
  adminProfile         Admin?
  hospitals            Hospital[]
  offers               Offer[]
  reviews              Review[]
  serviceWorkers       ServiceWorker[]
  district             District?       @relation(fields: [districtId], references: [id])
  orders               Order[]

  @@index([role])
  @@index([createdAt])
  @@index([isAdmin])
  @@index([districtId])
  @@map("User")
}

model Banner {
  id        Int      @id @default(autoincrement())
  image     String
  title     String?
  link      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("Banner")
}

model BusTimetable {
  id            Int       @id @default(autoincrement())
  districtId    Int?      @map("district_id")
  fromCity      String    @map("from_city")
  toCity        String    @map("to_city")
  firstBusTime  String    @map("first_bus_time")
  lastBusTime   String    @map("last_bus_time")
  fare          String
  boardingPoint String    @map("boarding_point")
  isActive      Boolean?  @default(true) @map("is_active")
  busType       String?   @default("General") @map("bus_type")
  travelTime    String?   @map("travel_time")
  operatorName  String?   @default("Local Operator") @map("operator_name")
  frequency     String?   @default("Daily")
  publicNote    String?   @map("public_note")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  district      District? @relation("DistrictToBuses", fields: [districtId], references: [id])

  @@map("BusTimetable")
}

model SchoolInquiry {
  id           String    @id @default(uuid()) @db.Uuid
  studentName  String    @db.VarChar(255)
  parentName   String    @db.VarChar(255)
  mobileNumber String    @db.VarChar(20)
  class        String    @db.VarChar(50)
  schoolId     Int?
  schoolName   String?   @db.VarChar(255)
  status       String?   @default("pending") @db.VarChar(50)
  notes        String?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@map("SchoolInquiry")
}

model Admin {
  id         Int       @id @default(autoincrement())
  role       String    @default("CITY_ADMIN")
  createdAt  DateTime  @default(now())
  districtId Int?      @map("district_id")
  updatedAt  DateTime  @updatedAt
  userId     Int       @unique @map("user_id")
  district   District? @relation(fields: [districtId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Admin")
}

model Lead {
  id            String   @id @default(uuid())
  shopId        Int?
  shopName      String?
  customerName  String?
  customerPhone String?
  message       String?
  source        String   @default("website")
  action        String   @default("click")
  metadata      Json?
  status        String   @default("new")
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([source])
  @@map("Lead")
}

model AnalyticsEvent {
  id         String    @id @default(uuid())
  eventType  String
  vendorId   Int?
  districtId Int?      @map("district_id")
  source     String?
  action     String?
  value      Json?
  userId     Int?
  sessionId  String?
  createdAt  DateTime  @default(now())
  district   District? @relation("DistrictToAnalytics", fields: [districtId], references: [id])

  @@map("AnalyticsEvent")
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  eventType   String
  status      String    @default("pending")
  payload     Json?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([provider, eventId])
  @@index([provider, status, createdAt])
  @@map("WebhookEvent")
}

model Metric {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Int    @default(0)

  @@map("Metric")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("ProductImage")
}

model Order {
  id              Int      @id @default(autoincrement())
  userId          Int?     @map("user_id")
  productId       Int      @map("product_id")
  vendorId        Int?     @map("vendor_id")
  districtId      Int?     @map("district_id")
  quantity        Int      @default(1)
  totalPrice      Float    @map("total_price")
  status          String   @default("pending")
  customerName    String?  @map("customer_name")
  customerPhone   String?  @map("customer_phone")
  customerAddress String?  @map("customer_address")
  paymentStatus   String?  @default("pending") @map("payment_status")
  paymentMethod   String?  @map("payment_method")
  paymentId       String?  @map("payment_id")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@index([customerPhone])
  @@index([status])
  @@index([vendorId])
  @@map("orders")
}

model ServiceWorker {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  districtId   Int      @map("district_id")
  name         String
  slug         String   @unique
  phone        String
  email        String?
  address      String?
  description  String?
  image        String?
  serviceType  String   @default("general")
  isAvailable  Boolean  @default(true)
  serviceArea  String?
  serviceHours String?
  basePrice    Decimal? @db.Decimal(10, 2)
  hourlyRate   Decimal? @db.Decimal(10, 2)
  skillTags    String[]
  experience   Int?
  rating       Decimal? @default(0) @db.Decimal(3, 2)
  reviewCount  Int      @default(0)
  isVerified   Boolean  @default(false)
  dsslScore    Int      @default(100)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  district     District @relation("DistrictToServiceWorkers", fields: [districtId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id])

  @@index([districtId])
  @@index([serviceType])
  @@index([isAvailable])
  @@map("ServiceWorker")
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessType {
  PRODUCT
  SERVICE
  HEALTHCARE
  SCHOOL
  RETAIL
  EDUCATION
}

enum InquiryType {
  LEAD
  APPOINTMENT
  GENERAL
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
