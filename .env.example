# ============================================
# SHAHDOL BAZAAR - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ============================================
# REQUIRED VARIABLES
# ============================================

# Database connection (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/shahdol_bazaar"

# JWT Secrets - Generate strong random strings (minimum 64 characters)
# Generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-min-64-characters-long"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-min-64-characters-long"

# Session Secret (for backward compatibility)
SESSION_SECRET="your-session-secret"

# ============================================
# CLOUDINARY (Image Upload)
# ============================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="shahdol-bazaar"

# ============================================
# CASHFREE (Payment Gateway)
# ============================================
# Mode: 'sandbox' or 'production'
CASHFREE_MODE="sandbox"
CASHFREE_APP_ID="your-app-id"
CASHFREE_SECRET_KEY="your-secret-key"
# Webhook secret for signature verification
CASHFREE_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# OPTIONAL SERVICES
# ============================================

# Groq AI (for AI features - REQUIRED for /api/ai/* endpoints)
GROQ_API_KEY="your-groq-api-key"

# Twilio WhatsApp (for notifications)
# TWILIO_ACCOUNT_SID="your-twilio-sid"
# TWILIO_AUTH_TOKEN="your-twilio-token"
# TWILIO_WHATSAPP_NUMBER="+1234567890"

# ============================================
# WHATSAPP ALERT STRIKE SYSTEM (Real-time Vendor Notifications)
# ============================================
# Webhook URL for WhatsApp message delivery (required for alerts)
WHATSAPP_WEBHOOK_URL="https://your-whatsapp-provider.com/webhook"

# Primary WhatsApp number for order alerts (fallback: master admin)
# Format: +911234567890 (with country code)
WHATSAPP_ALERT_NUMBER="+919999999999"

# Optional: WhatsApp API Key for authentication
# WHATSAPP_API_KEY="your-whatsapp-api-key"

# OneSignal (for push notifications)
# VITE_ONESIGNAL_APP_ID="your-onesignal-app-id"
# ONESIGNAL_API_KEY="your-onesignal-rest-api-key"

# ============================================
# CONFIGURATION
# ============================================

# Frontend URL (for payment redirects, emails, etc.)
# CLIENT_URL="https://shahdolbazaar.com"
# FRONTEND_URL="https://shahdolbazaar.com"

# Node environment
NODE_ENV="development"

# Server port (default: 5002)
PORT="5002"

# ============================================
# SECURITY SETTINGS
# ============================================

# Enable/disable webhook signature verification
# Set to 'false' only for local testing
# WEBHOOK_VERIFY="true"
