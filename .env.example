# ========================================================
# 🛡️ BHARATOS - EXAMPLE ENV (Copy to .env for local dev)
# ========================================================
PORT=5002
NODE_ENV=development
LOG_LEVEL=debug

# 🌐 URLs
VITE_APP_URL=http://localhost:5002
VITE_API_URL=http://localhost:5002/api
CLIENT_URL=http://localhost:5002
FRONTEND_URL=http://localhost:5002

# 📍 District
VITE_DEFAULT_DISTRICT_ID=121
VITE_DEFAULT_DISTRICT_SLUG=shahdol

# 🗄️ Database (use local or Neon)
DATABASE_URL=postgresql://user:pass@localhost:5432/shahdol_bazaar?connection_limit=5

# 🔐 Secrets (generate random strings)
SESSION_SECRET=dev-session-secret-change-me
JWT_SECRET=dev-jwt-secret-change-me
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me

# 💳 Cashfree (sandbox)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_MODE=sandbox
# 🔐 Cashfree Webhook Secret (for HMAC SHA256 webhook verification)
CASHFREE_WEBHOOK_SECRET=

# 🧠 AI (Optional)
GROQ_API_KEY=

# ☁️ Cloudinary (Optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 🚦 Performance
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DSSL_ENABLED=false
