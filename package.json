{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "npx tsc -p tsconfig.dev.json --noEmit 2>nul; exit 0",
    "predev:server": "npx kill-port 5002",
    "prebuild": "echo 'Skipping typecheck for build speed'",
    "build:client": "prisma generate && vite build",
    "build:server": "echo 'Server does not need build - runs via tsx'",
    "build": "npm run build:client",
    "dev": "npx kill-port 5174 && vite --force",
    "dev:server": "tsx watch server/index.ts",
    "dev:backend": "cross-env NODE_ENV=development tsx server/index.ts",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "start:dev": "cross-env NODE_ENV=production PORT=5002 tsx server/index.ts",
    "start:render": "cross-env NODE_ENV=production tsx server/index.ts",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit --skipLibCheck 2>nul || echo 'typecheck skipped'",
    "generate-types": "tsx server/lib/typeGenerator.ts",
    "embeddings": "tsx scripts/generate-embeddings.ts",
    "reset-embeddings": "tsx scripts/reset-embeddings.ts",
    "db:seed": "npx prisma db seed",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "diagnostic:deep": "tsx server/scripts/audit.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "prepare": "husky || true",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 100",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
