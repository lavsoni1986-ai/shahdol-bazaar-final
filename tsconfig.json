{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["client/src/*"],
      "@/components/*": ["client/src/components/*"],
      "@/lib/*": ["client/src/lib/*"],
      "@/hooks/*": ["client/src/hooks/*"],
      "@/pages/*": ["client/src/pages/*"],
      "@/contexts/*": ["client/src/contexts/*"],
      "@/constants/*": ["client/src/constants/*"],
      "@/types/*": ["client/src/types/*"],
      "@/shared/*": ["client/src/shared/*", "./shared/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "client/src/**/*",
    "server/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "server/tests",
    "server/services/system.health.ts",
    "server/services/user.intelligence.ts",
    "server/services/webhookHandler.ts",
    "server/shared/cognition/entity-search-indexing.ts",
    "server/ai/provider-manager.ts",
    "server/dto/entity.dto.ts",
    "server/events/index.ts",
    "server/lib/cognition/confidence.engine.ts",
    "server/lib/cognition/grounding.engine.ts",
    "server/lib/cognition/no-result-orchestrator.ts",
    "server/lib/cognition/response-synthesis.engine.ts",
    "server/lib/entityNormalization.ts",
    "server/lib/grounding/transport-adapter.ts",
    "server/lib/humanization.ts",
    "server/lib/observability.ts",
    "server/lib/realtime.ts",
    "server/lib/swagger.ts",
    "server/middleware/sovereign-logger.ts",
    "archive/**",
    "client/src/pages/archive/**",
    "client/src/components/archive/**",
    "client/src/archive/**"
  ]
}