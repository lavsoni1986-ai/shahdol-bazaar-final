// AI Provider Authority Environment Variables Template
// Add these to your .env file

// GROQ (Fast, Cheap - Primary for search)
// GROQ_API_KEY=your_groq_api_key_here

// OPENAI (Reasoning, Vision - Primary for complex tasks)
// OPENAI_API_KEY=your_openai_api_key_here

// ANTHROPIC (High-quality reasoning - Primary for refinement)
// ANTHROPIC_API_KEY=your_anthropic_api_key_here

// GEMINI (Multimodal, Fast - Primary for vision/analysis)
// GEMINI_API_KEY=your_gemini_api_key_here

// Future: Local models
// LOCAL_LLM_ENDPOINT=http://localhost:8000
// LOCAL_LLM_MODEL=your-local-model-name